# =============================================================================
# Admin Starter — Variables de Entorno
# =============================================================================
# Copia este archivo como .env y ajusta los valores según tu entorno.

# Base de Datos PostgreSQL
DATABASE_URL="postgresql://usuario:contraseña@localhost:5432/admin_starter"

# JWT — Clave secreta para firmar tokens de sesión (mínimo 32 caracteres)
# Generar con: openssl rand -base64 32
JWT_SECRET="cambia-esto-por-una-clave-segura-de-al-menos-32-caracteres"

# Entorno (development | production)
NODE_ENV="development"

# URL pública del sitio (usada por sitemap.xml y robots.txt)
NEXT_PUBLIC_SITE_URL="https://tudominio.com"

# =============================================================================
# Opcionales — Solo necesarios si usas Dropbox para uploads
# =============================================================================
# DROPBOX_ACCESS_TOKEN=""
# DROPBOX_REFRESH_TOKEN=""
# DROPBOX_APP_KEY=""
# DROPBOX_APP_SECRET=""
